# ──────────────────────────────────────────────────────────────────────────────
# DealRoom AI — Environment Variables
#
# IMPORTANT: Copy this file to `.env` and fill in your values.
# All sensitive secrets (API keys, passwords, DB URLs) are stored in Vault.
# The only things in .env are the Vault connection details and non-sensitive config.
#
# Bootstrap:
#   docker compose up vault vault-init   ← seeds all secrets into Vault
#   docker compose up                    ← starts everything else
# ──────────────────────────────────────────────────────────────────────────────

# ── Vault (the ONLY secrets allowed in .env) ──────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token          # dev mode only; use AppRole in production
# VAULT_ROLE_ID=                    # production AppRole role ID
# VAULT_SECRET_ID=                  # production AppRole secret ID

# ── Non-sensitive config ──────────────────────────────────────────────────────
APP_ENV=development                 # development | production
API_VERSION=v1

# LLM / Embedding models
LLM_MODEL=gpt-4o
CHEAP_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# MinIO (non-sensitive config — credentials come from Vault)
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=dealroom-documents
MINIO_SECURE=false

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ML
ML_MODEL_PATH=/app/ml/artifacts/risk_classifier.pkl
MAX_UPLOAD_SIZE_MB=50

# Cache TTLs (seconds)
EMBEDDING_CACHE_TTL=604800          # 7 days
RESEARCH_CACHE_TTL=86400            # 24 hours
ML_CACHE_TTL=0                      # indefinite

# Observability (optional)
SENTRY_DSN=
# Leave SENTRY_DSN empty to disable Sentry error tracking

LANGCHAIN_API_KEY=your_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=dealroom-research

# ── All other secrets come from Vault ─────────────────────────────────────────
# Populated automatically by:  docker compose up vault-init
#
#   DATABASE_URL        → secret/dealroom/database#url
#   REDIS_URL           → secret/dealroom/redis#url
#   SECRET_KEY          → secret/dealroom/auth#secret_key
#   OPENAI_API_KEY      → secret/dealroom/openai#api_key
#   LANGCHAIN_API_KEY   → secret/dealroom/langsmith#api_key
#   MINIO_ACCESS_KEY    → secret/dealroom/minio#access_key
#   MINIO_SECRET_KEY    → secret/dealroom/minio#secret_key
#   SMTP_PASSWORD       → secret/dealroom/email#smtp_password
#   TAVILY_API_KEY      → secret/dealroom/research#tavily_key
#   NEWS_API_KEY        → secret/dealroom/research#news_api_key
#   ALPHA_VANTAGE_KEY   → secret/dealroom/research#alpha_vantage_key
